[
  {
    "type": "add_style",
    "content": ".m-page-loading-wrap, .af-smart-banner, .m-dialog-mask, .m-ad-message { display: none !important; pointer-events: none !important; }"
  },
  {
    "type": "wait",
    "selector": ".m-btn-login",
    "state": "visible"
  },
  {
    "type": "click",
    "selector": ".m-btn-login"
  },
  {
    "type": "wait",
    "selector": "input[type='tel']",
    "state": "visible"
  },
  {
    "type": "input",
    "selector": "input[type='tel']",
    "value": "{USERNAME}",
    "delay": 50
  },
  {
    "type": "input",
    "selector": "input[type='password']",
    "value": "{PASSWORD}",
    "delay": 50
  },
  {
    "type": "wait",
    "timeout": 500
  },
  {
    "type": "click",
    "selector": ".login-btn"
  }
]
